{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "#7aa2f7",
          "template": " {{ if .WSL }}wsl{{ else }}{{ .Icon }}{{ end }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#7dcfff",
          "properties": {
            "style": "folder"
          },
          "template": "{{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#bb9af7",
          "properties": {
            "branch_icon": "git ",
            "fetch_status": true
          },
          "template": "{{ .HEAD }}{{ if or .Working.Changed .Staging.Changed }} {{ .Working.String }}{{ .Staging.String }}{{ end }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#e0af68",
          "properties": {
            "threshold": 500
          },
          "template": "{{ .FormattedMs }} "
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#565f89",
          "properties": {
            "time_format": "15:04"
          },
          "template": "{{ .CurrentDate | date .Format }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#9ece6a",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f7768e{{ end }}"
          ],
          "template": "> "
        }
      ]
    }
  ]
}
